# Copy to `.env` and adjust values. Used by Sequelize (`lib/db.ts`) and the app URL (`app/recientes/page.tsx`).

# MySQL — must match your local or hosted database
DB_HOST=localhost
DB_NAME=url_shortener
DB_USER=root
DB_PASSWORD=

# Public base URL for the app (NEXT_PUBLIC_* is exposed to the browser).
# Local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: HTTP port for `next start` (default 3000). The Dockerfile sets 8001.
# PORT=3000
