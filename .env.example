# Copy to `.env` and adjust values.

# MySQL — must match your local or hosted database
DB_HOST=localhost
DB_NAME=url_shortener
DB_USER=root
DB_PASSWORD=

# Separate database used by the integration test suite (npm run test:integration)
DB_NAME_TEST=cortala_test

# Public base URL for the app (NEXT_PUBLIC_* is exposed to the browser).
# Local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth.js (next-auth v5) — secret used to sign session JWTs.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Optional: HTTP port for `next start` (default 3000). The Dockerfile sets 8001.
# PORT=3000
