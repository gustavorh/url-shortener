{
  "name": "cortala",
  "version": "0.1.0",
  "private": true,
  "description": "Cortala monorepo — web app, shared schemas, CLI, browser extension.",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @cortala/web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @cortala/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm --filter @cortala/web test:integration",
    "worker": "pnpm --filter @cortala/web worker",
    "worker:dev": "pnpm --filter @cortala/web worker:dev",
    "webhook-worker": "pnpm --filter @cortala/web webhook-worker",
    "webhook-worker:dev": "pnpm --filter @cortala/web webhook-worker:dev",
    "db:migrate": "pnpm --filter @cortala/web db:migrate",
    "db:migrate:undo": "pnpm --filter @cortala/web db:migrate:undo",
    "db:migrate:undo:all": "pnpm --filter @cortala/web db:migrate:undo:all"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
