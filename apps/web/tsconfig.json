{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@linkly/schemas": ["../../packages/schemas/src/index.ts"],
      "@linkly/schemas/v1": ["../../packages/schemas/src/v1.ts"],
      "@linkly/schemas/webhooks": ["../../packages/schemas/src/webhooks.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/schemas/src/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
