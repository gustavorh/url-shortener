{
  "name": "@cortala/web",
  "version": "0.1.0",
  "private": true,
  "description": "Cortala — acortador de URLs full-stack con analítica, API pública y panel de control (Next.js, TypeScript, MySQL).",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --no-file-parallelism",
    "worker": "tsx scripts/start-worker.ts",
    "worker:dev": "tsx watch scripts/start-worker.ts",
    "webhook-worker": "tsx scripts/start-webhook-worker.ts",
    "webhook-worker:dev": "tsx watch scripts/start-webhook-worker.ts",
    "notifications:worker": "tsx scripts/start-notifications-worker.ts",
    "notifications:worker:dev": "tsx watch scripts/start-notifications-worker.ts",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/generate-openapi.ts && git diff --exit-code public/openapi.json",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "@cortala/schemas": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/swagger-ui": "^5.32.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.1",
    "date-fns": "^4.1.0",
    "geoip-lite": "^2.0.2",
    "ioredis": "^5.10.1",
    "mysql2": "^3.12.0",
    "next": "15.2.0",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^11.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sequelize": "^6.37.5",
    "swagger-ui-dist": "^5.32.6",
    "tailwindcss": "^4",
    "ua-parser-js": "^2.0.10",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "happy-dom": "^20.9.0",
    "sequelize-cli": "^6.6.5",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
