# Copy to `.env` and adjust values.

# MySQL — must match your local or hosted database
DB_HOST=localhost
DB_NAME=url_shortener
DB_USER=root
DB_PASSWORD=

# Separate database used by the integration test suite (pnpm test:integration)
DB_NAME_TEST=cortala_test

# Public base URL for the app (NEXT_PUBLIC_* is exposed to the browser).
# Local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth.js (next-auth v5) — secret used to sign session JWTs.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Optional: Redis URL. Enables redirect caching, distributed rate limiting
# and the BullMQ click queue. When unset, the app uses MySQL + in-process
# limits and writes clicks synchronously from the redirect path.
# Example: redis://localhost:6379
REDIS_URL=

# Optional: force the click queue off even when REDIS_URL is set. Useful
# when running the Next.js app without a worker — clicks fall back to
# synchronous writes from the redirect path.
# CLICK_QUEUE_DISABLED=

# Optional: number of click jobs processed in parallel by the worker.
# Default 5. Tune up for high-traffic environments.
# CLICK_WORKER_CONCURRENCY=

# Optional: OAuth — GitHub. When set, /login y /register muestran el
# botón "Continuar con GitHub". Crea una OAuth App en
# https://github.com/settings/developers con la callback
# `<NEXT_PUBLIC_BASE_URL>/api/auth/callback/github`.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Optional: OAuth — Google. Crea un OAuth Client en
# https://console.cloud.google.com/apis/credentials con la callback
# `<NEXT_PUBLIC_BASE_URL>/api/auth/callback/google`.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Google Safe Browsing API key. When set, shortened URLs are
# checked against known malware/phishing threats before creation.
SAFE_BROWSING_API_KEY=

# Optional: HTTP port for `next start` (default 3000). The Dockerfile sets 8001.
# PORT=3000
